# =========================================
# App
# =========================================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=replace-with-a-secret-key-at-least-32-characters-long
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
SKIP_STARTUP_CHECKS=false
HEALTH_CHECK_EXTERNAL=true

# =========================================
# Database
# =========================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/food_analyzer
DATABASE_SYNC_URL=postgresql+psycopg://postgres:password@localhost:5432/food_analyzer

# =========================================
# Redis
# =========================================
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# =========================================
# MinIO
# =========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=food-analyzer

# =========================================
# PaddleOCR (在线 API)
# =========================================
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_TOKEN=replace-with-paddleocr-token
PADDLEOCR_MODEL=PaddleOCR-VL-1.5
PADDLEOCR_NUTRITION_MODEL=PP-StructureV3
PADDLEOCR_OTHER_MODEL=PaddleOCR-VL-1.5

# Detection params
PADDLEOCR_DET_DB_BOX_THRESH=0.5
PADDLEOCR_DET_DB_UNCLIP_RATIO=1.8
PADDLEOCR_TEXT_DET_LIMIT_SIDE_LEN=960
PADDLEOCR_TEXT_DET_LIMIT_TYPE=max
PADDLEOCR_TEXT_DET_THESH=0.3

# Preprocessing
PADDLEOCR_USE_DOC_ORIENTATION_CLASSIFY=true
PADDLEOCR_USE_DOC_UNWARPING=true
PADDLEOCR_USE_TEXTLINE_ORIENTATION=true

# Table recognition
PADDLEOCR_USE_TABLE_RECOGNITION=true
PADDLEOCR_USE_E2E_WIRED_TABLE_REC_MODEL=false
PADDLEOCR_USE_E2E_WIRELESS_TABLE_REC_MODEL=true

# Timing
PADDLEOCR_POLL_INTERVAL_S=5.0
PADDLEOCR_POLL_TIMEOUT_S=300.0
PADDLEOCR_REQUEST_TIMEOUT_S=60.0

# =========================================
# DeepSeek
# =========================================
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=120
DEEPSEEK_TEMPERATURE=0.0
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_MAX_TOKENS=600

# =========================================
# Ollama
# =========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:latest
OLLAMA_EMBEDDING_TIMEOUT_S=30.0

# =========================================
# ChromaDB
# =========================================
CHROMADB_PATH=./chroma_data
CHROMADB_COLLECTION_INGREDIENTS=gb2760_a1_grouped
CHROMADB_COLLECTION_STANDARDS=gb2760_a1_grouped

# =========================================
# YOLO (ultralytics)
# =========================================
YOLO_MODEL_PATH=./models_store/yolo/yolo26s.onnx
YOLO_CONFIDENCE_THRESHOLD=0.7
YOLO_INPUT_SIZE=640
YOLO_SELECT_TOP_K=5
YOLO_CROP_PADDING=10

# =========================================
# Scoring Weights
# =========================================
SCORE_WEIGHT_NUTRITION=0.30
SCORE_WEIGHT_SODIUM=0.25
SCORE_WEIGHT_ADDITIVES=0.20
SCORE_WEIGHT_ALLERGENS=0.15
SCORE_WEIGHT_SUGAR=0.10

# =========================================
# Ingredient Extraction
# =========================================
INGREDIENT_TEXT_LIMIT=500
INGREDIENT_MIN_TERM_LENGTH=2

# =========================================
# RAG Retrieval
# =========================================
RAG_TOP_K_INGREDIENTS=5
RAG_TOP_K_STANDARDS=10

# =========================================
# JWT
# =========================================
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================
# SMTP
# =========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_NAME=Food Label Analyzer
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# =========================================
# Task
# =========================================
USER_MAX_CONCURRENT_TASKS=3

# =========================================
# Upload
# =========================================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# =========================================
# CORS
# =========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =========================================
# Logging
# =========================================
LOG_LEVEL=DEBUG
LOG_FORMAT=console
SENTRY_DSN=
