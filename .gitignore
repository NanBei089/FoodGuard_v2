# Root allowlist: only keep these project folders and this file.
/*
!/.gitignore
!/docs/
!/food-label-analyzer/
!/food-label-frontend/

# Python
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.so

# Virtual environments and local config
**/venv/
**/.venv/
**/ocr-venv/
**/__pypackages__/
**/.env
**/.env.*
!/food-label-analyzer/.env.example
!/food-label-frontend/.env.example
**/.python-version
**/*.local

# Editors and OS files
**/.idea/
**/.vscode/*
!/food-label-analyzer/.vscode/settings.json
!/food-label-frontend/.vscode/extensions.json
**/*.code-workspace
**/*.swp
**/*.swo
**/.DS_Store
**/Thumbs.db
Desktop.ini

# Coverage, caches, test artifacts
**/.coverage
**/.coverage.*
**/htmlcov/
**/coverage.xml
**/.pytest_cache/
**/.pytest_cache_local/
**/pytest-cache-files-*/
**/.hypothesis/
**/.tox/
**/.nox/
**/.ipynb_checkpoints/
**/.mypy_cache/
**/.ruff_cache/
**/.pytype/
**/.pyre/
**/.black_cache/
**/.cache/
**/.tmp/
**/*.tmp
**/*.bak

# Build outputs and package-manager installs
**/dist/
**/dist-ssr/
**/build/
**/*.egg-info/
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# Logs and runtime files
**/*.log
**/logs/
**/celerybeat-schedule
**/celerybeat.pid

# Local databases and large runtime assets
**/*.db
**/*.sqlite3
**/*.sqlite
/food-label-analyzer/models_store/
/food-label-analyzer/chroma_data/
/food-label-analyzer/minio_data/
